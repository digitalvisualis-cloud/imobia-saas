    {
      "id": "http-claude",
      "name": "gerar_texto_claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -420,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"claude-haiku-4-5-20251001\", \"max_tokens\": 2500, \"messages\": [{\"role\": \"user\", \"content\": \"=Voc\\u00ea \\u00e9 um copywriter especialista em imobili\\u00e1rias de alto padr\\u00e3o. Escreve em portugu\\u00eas do Brasil. Tom persuasivo, elegante, sem exageros vazios.\\n\\nCONTEXTO:\\n{{ JSON.stringify($('setar_dados').item.json.imovel) }}\\n\\nBRAND KIT:\\n{{ JSON.stringify($('setar_dados').item.json.imobiliaria.brand_kit) }}\\n\\nTAREFA: Retorne EXATAMENTE um JSON v\\u00e1lido (sem markdown, sem code fence) com essa estrutura:\\n\\n{\\n  \\\"descricao_longa\\\": \\\"texto de 800-1200 caracteres pra ficha do im\\u00f3vel\\\",\\n  \\\"legenda_post_instagram\\\": \\\"legenda at\\u00e9 2200 chars com emojis estrat\\u00e9gicos + 8-12 hashtags no final\\\",\\n  \\\"texto_story\\\": \\\"texto curto (m\\u00e1x 120 chars) pra overlay no story 9:16\\\",\\n  \\\"slides_carrusel\\\": [\\n    {\\\"titulo\\\": \\\"...\\\", \\\"descricao\\\": \\\"...\\\"},\\n    {\\\"titulo\\\": \\\"...\\\", \\\"descricao\\\": \\\"...\\\"},\\n    {\\\"titulo\\\": \\\"...\\\", \\\"descricao\\\": \\\"...\\\"},\\n    {\\\"titulo\\\": \\\"...\\\", \\\"descricao\\\": \\\"...\\\"},\\n    {\\\"titulo\\\": \\\"...\\\", \\\"descricao\\\": \\\"...\\\"}\\n  ],\\n  \\\"email_html\\\": \\\"HTML inline pronto pra Gmail\\\",\\n  \\\"voiceover_script\\\": \\\"texto corrido para TTS, sem emoji, com pontua\\u00e7\\u00e3o natural\\\",\\n  \\\"guion_escenas_revisado\\\": [\\n    {\\\"slug\\\": \\\"fachada\\\", \\\"titulo\\\": \\\"...\\\", \\\"texto\\\": \\\"...\\\", \\\"ordem\\\": 0}\\n  ]\\n}\\n\\nREGRAS:\\n- Portugu\\u00eas do Brasil sempre\\n- Nunca invente caracter\\u00edsticas (s\\u00f3 mencione o que est\\u00e1 no contexto)\\n- Pre\\u00e7o em R$ com formata\\u00e7\\u00e3o brasileira (R$ 8.500.000)\\n- Tom: {{ $('setar_dados').item.json.imovel.voiceover_tom || 'profissional' }}\\n- Retorne APENAS o JSON, sem texto antes ou depois\"}]}",
        "options": {
          "timeout": 90000
        }
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "id": "code-parse-claude",
      "name": "extrair_textos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -160,
        300
      ],
      "parameters": {
        "jsCode": "// Claude retorna { content: [{ type: 'text', text: '...' }] }\nconst raw = $input.first().json.content?.[0]?.text ?? \"\";\nconst cleaned = raw.trim().replace(/^```(?:json)?\\s*/i, \"\").replace(/\\s*```$/i, \"\");\n\nlet textos;\ntry {\n  textos = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error(\"Claude não retornou JSON válido: \" + cleaned.slice(0, 300));\n}\n\nconst ctx = $('setar_dados').item.json;\n\nreturn [{\n  json: {\n    ...ctx,\n    textos: textos,\n    prompt_imagem_post: `Professional real estate marketing image, 1:1 square. ${ctx.imovel.tipo} in ${ctx.imovel.bairro}, ${ctx.imovel.cidade}. Modern luxury style, warm lighting, architectural photography. Overlay: property title \"${ctx.imovel.titulo}\", price \"R$ ${Number(ctx.imovel.preco).toLocaleString('pt-BR')}\", agency logo watermark bottom-right in color ${ctx.imobiliaria.brand_kit?.primary_color || '#C9A227'}. Clean serif typography for title. Subtle gradient background. No text artifacts.`,\n    prompt_imagem_story: `Professional Instagram Story, 9:16 vertical. ${ctx.imovel.tipo}, ${ctx.imovel.quartos} bedrooms, ${ctx.imovel.area_m2}m² in ${ctx.imovel.bairro}. Bold modern design, property photo top 60%, bottom 40% solid block in color ${ctx.imobiliaria.brand_kit?.primary_color || '#C9A227'} with text \"${textos.texto_story}\" in large white sans-serif, price \"R$ ${Number(ctx.imovel.preco).toLocaleString('pt-BR')}\" below. Swipe-up arrow at bottom edge. Mobile-first composition.`,\n  }\n}];\n",
        "language": "javaScript"
      }
    },

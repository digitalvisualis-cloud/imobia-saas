        "jsCode": "// Coleta URLs dos uploads\nconst ctx = $('extrair_textos').item.json;\nconst supabaseUrl = $env.SUPABASE_URL;\n\nconst basePath = `${supabaseUrl}/storage/v1/object/public/listapro/${ctx.tenant_id}/${ctx.imovel_id}`;\n\nreturn [{\n  json: {\n    ...ctx,\n    formatos: {\n      pdf_url: null,  // Entrega 2b: PDF via puppeteer\n      post_url: `${basePath}/post.png`,\n      story_url: `${basePath}/story.png`,\n      carrusel_urls: [],  // Entrega 2c\n      email_html: ctx.textos.email_html,\n      audio_url: null,  // Entrega 3\n      video_url: null,  // Entrega 3\n    }\n  }\n}];\n",

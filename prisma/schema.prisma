generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── TENANTS (imobiliárias/corretores) ─────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // URL do site: imobia.io/slug
  plano     Plano    @default(FREE)
  stripeCustomerId  String?
  stripeSubId       String?
  planExpiresAt     DateTime?
  // Token usado nos feeds XML públicos pros portais (ZAP/Chaves/etc).
  // Não é secret crítico (URL pública), mas se vazar dá pra rotacionar.
  feedToken String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  imoveis   Imovel[]
  leads     Lead[]
  marca     ConfigMarca?
  agente    AgenteIA?
  site      Site?
  posts     PostGerado[]
  eventos   AgendaEvento[]
  contratos Contrato[]

  @@map("tenants")
}

enum Plano {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ─── USERS ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String?
  nome         String
  whatsapp     String?
  creci        String?
  role         Role     @default(CORRETOR)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts     Account[]
  sessions     Session[]
  eventos      AgendaEvento[] @relation("AgendaResponsavel")

  @@map("users")
}

enum Role {
  ADMIN
  CORRETOR
  VIEWER
}

// NextAuth adapters
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── IMÓVEIS ───────────────────────────────────────────────────────────────

model Imovel {
  id           String          @id @default(cuid())
  tenantId     String
  codigo       String          // IMV-XXXXXX
  titulo       String
  descricao    String?
  tipo         TipoImovel
  operacao     Operacao
  status       StatusImovel    @default(DISPONIVEL)
  preco        Decimal         @db.Decimal(15, 2)
  quartos      Int             @default(0)
  banheiros    Int             @default(0)
  suites       Int             @default(0)
  vagas        Int             @default(0)
  areaM2       Decimal?        @db.Decimal(10, 2)
  areaTotal    Decimal?        @db.Decimal(10, 2)
  areaTerrenoM2 Decimal?       @db.Decimal(10, 2)
  pisos        Int?
  estado       String          @default("SP")
  cidade       String
  bairro       String?
  endereco     String?
  cep          String?
  imagens      String[]
  capaUrl      String?
  videoUrl     String?
  amenidades   String[]
  amenidadesOutras String?
  notas        String?
  destaque     Boolean         @default(false)
  publicado    Boolean         @default(true)
  visualizacoes Int            @default(0)
  
  // ListaPro Fields
  videoTipo         String?
  voiceoverVoz      String?
  voiceoverTom      String?
  voiceoverContexto String?
  guionEscenas      Json?
  formatosGerados   Json?
  statusGeracao     ListaProStatus?
  statusGeracaoErro String?
  geradoAt          DateTime?
  
  // Contato Específico
  agenteNome        String?
  agenteTelefone    String?
  agenteEmail       String?
  agenciaNome       String?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads        Lead[]
  posts        PostGerado[]
  eventos      AgendaEvento[]
  contratos    Contrato[]

  @@unique([tenantId, codigo])
  @@index([tenantId, status])
  @@index([tenantId, publicado])
  @@index([tenantId, tipo])
  @@index([tenantId, operacao])
  @@index([tenantId, cidade])
  @@map("imoveis")
}

enum TipoImovel {
  APARTAMENTO
  CASA
  CHACARA
  SITIO
  TERRENO
  COMERCIAL
  STUDIO
  COBERTURA
  SALA_COMERCIAL
  LOJA
  GALPAO
}

enum Operacao {
  VENDA
  ALUGUEL
  TEMPORADA
}

enum StatusImovel {
  DISPONIVEL
  RESERVADO
  VENDIDO
  ALUGADO
  INATIVO
}

enum ListaProStatus {
  RASCUNHO
  GERANDO
  PRONTO
  ERRO
}

// ─── LEADS / KANBAN ────────────────────────────────────────────────────────

model Lead {
  id              String      @id @default(cuid())
  tenantId        String
  imovelId        String?
  nome            String
  whatsapp        String?
  email           String?
  etapa           EtapaLead   @default(NOVO)
  temperatura     Temperatura @default(MORNO)
  interesse       String?     // tipo de imóvel que busca
  bairroDesejado  String?
  orcamento       Decimal?    @db.Decimal(15, 2)
  resumoConversa  String?
  dataVisita      DateTime?
  followUp1       DateTime?
  followUp2       DateTime?
  followUp3       DateTime?
  // ChatWoot
  chatwootContactId   String?
  chatwootConversaId  String?
  chatwootInboxId     String?
  // n8n
  n8nLeadId       String?
  origem          String?     // site, whatsapp, instagram, etc.
  notas           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel          Imovel?     @relation(fields: [imovelId], references: [id])
  eventos         AgendaEvento[]
  contratos       Contrato[]

  @@index([tenantId, etapa])
  @@index([tenantId, createdAt])
  @@map("leads")
}

enum EtapaLead {
  NOVO
  CONTATO
  VISITA_AGENDADA
  PROPOSTA
  FECHADO
  PERDIDO
}

enum Temperatura {
  FRIO
  MORNO
  QUENTE
}

// ─── MARCA / WHITE LABEL ───────────────────────────────────────────────────

model ConfigMarca {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  nomeEmpresa     String?
  slogan          String?
  descricao       String?
  logoUrl         String?
  faviconUrl      String?
  corPrimaria     String   @default("#7c3aed")
  corSecundaria   String   @default("#06b6d4")
  fonteTitulo     String?  @default("cormorant") // cormorant | playfair | lora | inter | montserrat
  fonteCorpo      String?  @default("inter")     // inter | system | montserrat | lora
  email           String?
  whatsapp        String?
  telefone        String?
  endereco        String?
  instagram       String?
  facebook        String?
  youtube         String?
  linkedin        String?
  tiktok          String?
  manualMarcaUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("config_marca")
}

// ─── AGENTE IA ─────────────────────────────────────────────────────────────

model AgenteIA {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  // ─── Persona ───
  nome            String   @default("Sofia")
  personalidade   String   @default("Consultivo e empático")
  apresentacao    String?
  // O que ele deve fazer no atendimento (objetivo)
  objetivo        ObjetivoAgente @default(QUALIFICAR)
  // Mensagens prontas
  mensagemSaudacao    String?
  mensagemForaHorario String?
  // Horário humano (fora disso, IA toma conta sem handoff)
  horarioInicio   String? // ex: "08:00"
  horarioFim      String? // ex: "20:00"
  diasSemana      Json     @default("[1,2,3,4,5]") // 0=dom 6=sab
  ativo           Boolean  @default(false)
  // ─── n8n ───
  usarN8n         Boolean  @default(true)
  webhookUrl      String?
  webhookSecret   String?
  // ─── ChatWoot ───
  usarChatwoot    Boolean  @default(false)
  chatwootUrl     String?
  chatwootToken   String?
  chatwootInboxId String?
  // ─── CRM externo do cliente (callback opcional) ───
  webhookSaidaCrm String?
  // ─── Chaves IA por tenant (NULL = usa master Visualis) ───
  // TODO: cifrar de verdade. Hoje plain text (débito técnico documentado).
  openaiApiKey      String?
  anthropicApiKey   String?
  elevenLabsApiKey  String?
  elevenLabsVoiceId String?
  remotionApiKey    String?
  textoProvider     TextoProvider @default(CLAUDE)
  // ─── Fluxo / etapas configuradas (legado, ainda usado) ───
  etapas          Json     @default("[]")
  // Extensibilidade futura
  metadados       Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agente_ia")
}

enum ObjetivoAgente {
  QUALIFICAR        // triagem e devolve pro corretor
  AGENDAR_VISITA    // qualifica + agenda direto
  TIRAR_DUVIDAS     // FAQ e info do imóvel
  HANDOFF_DIRETO    // passa pro corretor sem fazer nada
}

enum TextoProvider {
  CLAUDE
  OPENAI
}

// ─── LOGS ESTRUTURADOS ─────────────────────────────────────────────────────

model AiCallLog {
  id              String   @id @default(cuid())
  tenantId        String
  provider        String                          // 'anthropic' | 'openai' | 'elevenlabs' | 'openai-image'
  model           String?
  operation       String                          // 'chat' | 'image-gen' | 'tts' | 'embed' | 'other'
  keySource       String?                         // 'tenant' | 'master'
  promptPreview   String?
  responsePreview String?
  tokensInput     Int?
  tokensOutput    Int?
  costEstimateBrl Decimal? @db.Decimal(10, 4)
  latencyMs       Int?
  status          String   @default("success")    // 'success' | 'error' | 'rate_limited'
  error           String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([provider, createdAt(sort: Desc)])
  @@map("ai_call_logs")
}

model ApiRequestLog {
  id            String   @id @default(cuid())
  tenantId      String?
  route         String
  method        String
  status        Int
  latencyMs     Int?
  ip            String?
  userAgent     String?
  userId        String?
  errorMessage  String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([route, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("api_request_logs")
}

// ─── SITE WHITE-LABEL ──────────────────────────────────────────────────────

model Site {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  slug        String   @unique
  dominio     String?  @unique // domínio customizado
  titulo      String?
  publicado   Boolean  @default(false)
  templateId  String?  @default("elegance") // qual template visual está ativo
  config      Json?    // páginas e seções habilitadas (formato em lib/site-config.ts)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sites")
}

// ─── POSTS / ARTES GERADAS ─────────────────────────────────────────────────

model PostGerado {
  id         String     @id @default(cuid())
  tenantId   String
  imovelId   String?
  tipo       TipoPost
  conteudo   String
  imageUrl   String?
  createdAt  DateTime   @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel     Imovel?    @relation(fields: [imovelId], references: [id])

  @@index([tenantId])
  @@map("posts_gerados")
}

enum TipoPost {
  INSTAGRAM_FEED
  INSTAGRAM_STORIES
  WHATSAPP
  FICHA_PDF
  DESCRICAO_SITE
}

// ─── AGENDA ─────────────────────────────────────────────────────────────────

model AgendaEvento {
  id           String          @id @default(cuid())
  tenantId     String
  // Quem é responsável (corretor) — opcional, default = quem criou
  responsavelId String?
  // Vínculos opcionais
  imovelId     String?
  leadId       String?
  // Dados do evento
  titulo       String
  descricao    String?
  tipo         TipoEvento      @default(VISITA)
  status       StatusEvento    @default(AGENDADO)
  inicio       DateTime
  fim          DateTime
  diaInteiro   Boolean         @default(false)
  local        String?         // texto livre — endereço ou "WhatsApp", etc.
  // Lembretes
  lembrete15Min Boolean        @default(true)
  lembrete1Dia  Boolean        @default(false)
  // Integração futura com Google Calendar
  googleEventId String?
  // Auditoria
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responsavel  User?           @relation("AgendaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  imovel       Imovel?         @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  lead         Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId, inicio])
  @@index([tenantId, status])
  @@index([tenantId, responsavelId])
  @@map("agenda_eventos")
}

enum TipoEvento {
  VISITA
  RETORNO
  REUNIAO
  TAREFA
  OUTRO
}

enum StatusEvento {
  AGENDADO
  CONFIRMADO
  REALIZADO
  CANCELADO
  REMARCADO
}

// ─── FINANCEIRO / CONTRATOS ─────────────────────────────────────────────────

model Contrato {
  id              String          @id @default(cuid())
  tenantId        String
  // Vínculos opcionais — o cliente pode existir como Lead OU só como dados livres
  imovelId        String?
  leadId          String?
  // Dados do cliente (cópia direta — não depende do Lead)
  cliente         String          // Nome do cliente
  clienteCpfCnpj  String?
  clienteContato  String?         // WhatsApp ou email
  // Tipo e status
  tipo            TipoContrato    @default(VENDA)
  status          StatusContrato  @default(ATIVO)
  // Valores
  valor           Decimal         @db.Decimal(15, 2)
  comissaoPct     Decimal         @db.Decimal(5, 2) @default(0)  // ex: 5.00 (%)
  // Datas
  dataInicio      DateTime
  dataFim         DateTime?
  // Documento
  pdfUrl          String?         // URL do PDF (Storage no futuro)
  pdfNome         String?
  // Observações
  observacoes     String?
  // Auditoria
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel          Imovel?         @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  lead            Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, dataInicio])
  @@map("contratos")
}

enum TipoContrato {
  VENDA
  ALUGUEL
  ADMINISTRACAO
}

enum StatusContrato {
  ATIVO
  PENDENTE
  ENCERRADO
  CANCELADO
}

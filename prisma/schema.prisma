generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 nao aceita url no schema — vem do prisma.config.ts (migrate)
  // e do adapter no PrismaClient (runtime). Ver lib/prisma.ts.
}

// ─── TENANTS (imobiliárias/corretores) ─────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // URL do site: imobia.io/slug
  plano     Plano    @default(FREE)
  stripeCustomerId  String?
  stripeSubId       String?
  planExpiresAt     DateTime?
  // Token usado nos feeds XML públicos pros portais (ZAP/Chaves/etc).
  // Não é secret crítico (URL pública), mas se vazar dá pra rotacionar.
  feedToken String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  imoveis   Imovel[]
  leads     Lead[]
  marca     ConfigMarca?
  agente    AgenteIA?
  site      Site?
  posts     PostGerado[]
  eventos   AgendaEvento[]
  contratos Contrato[]
  conversas Conversa[]
  convites  EquipeConvite[]
  configWhatsApp ConfigWhatsApp?
  newsletterInscricoes NewsletterInscricao[]
  artigosBlog ArtigoBlog[]
  chaveRetiradas ChaveRetirada[]
  comissaoSplits ComissaoSplit[]
  repasses Repasse[]
  cobrancas Cobranca[]

  @@map("tenants")
}

enum Plano {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ─── USERS ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String?
  nome         String
  whatsapp     String?
  creci        String?
  role         Role     @default(CORRETOR)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts     Account[]
  sessions     Session[]
  eventos      AgendaEvento[] @relation("AgendaResponsavel")

  @@map("users")
}

enum Role {
  ADMIN
  CORRETOR
  VIEWER
}

// NextAuth adapters
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── IMÓVEIS ───────────────────────────────────────────────────────────────

model Imovel {
  id           String          @id @default(cuid())
  tenantId     String
  codigo       String          // IMV-XXXXXX
  titulo       String
  descricao    String?
  tipo         TipoImovel
  operacao     Operacao
  status       StatusImovel    @default(DISPONIVEL)
  preco        Decimal         @db.Decimal(15, 2)
  iptuMensal       Decimal? @db.Decimal(15, 2)
  condominioMensal Decimal? @db.Decimal(15, 2)
  quartos      Int             @default(0)
  banheiros    Int             @default(0)
  suites       Int             @default(0)
  vagas        Int             @default(0)
  areaM2       Decimal?        @db.Decimal(10, 2)
  areaTotal    Decimal?        @db.Decimal(10, 2)
  areaTerrenoM2 Decimal?       @db.Decimal(10, 2)
  pisos        Int?
  estado       String          @default("SP")
  cidade       String
  bairro       String?
  endereco     String?
  cep          String?
  imagens      String[]
  capaUrl      String?
  videoUrl     String?
  amenidades   String[]
  amenidadesOutras String?
  notas        String?
  destaque     Boolean         @default(false)
  publicado    Boolean         @default(true)
  visualizacoes Int            @default(0)
  
  // ListaPro Fields
  videoTipo         String?
  voiceoverVoz      String?
  voiceoverTom      String?
  voiceoverContexto String?
  guionEscenas      Json?
  formatosGerados   Json?
  statusGeracao     ListaProStatus?
  statusGeracaoErro String?
  geradoAt          DateTime?
  
  // Contato Específico
  agenteNome        String?
  agenteTelefone    String?
  agenteEmail       String?
  agenciaNome       String?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads        Lead[]
  posts        PostGerado[]
  eventos      AgendaEvento[]
  contratos    Contrato[]
  conversas    Conversa[]
  chaveRetiradas ChaveRetirada[]

  @@unique([tenantId, codigo])
  @@index([tenantId, status])
  @@index([tenantId, publicado])
  @@index([tenantId, tipo])
  @@index([tenantId, operacao])
  @@index([tenantId, cidade])
  @@map("imoveis")
}

enum TipoImovel {
  APARTAMENTO
  CASA
  CHACARA
  SITIO
  TERRENO
  COMERCIAL
  STUDIO
  COBERTURA
  SALA_COMERCIAL
  LOJA
  GALPAO
}

enum Operacao {
  VENDA
  ALUGUEL
  TEMPORADA
}

enum StatusImovel {
  DISPONIVEL
  RESERVADO
  VENDIDO
  ALUGADO
  INATIVO
}

enum ListaProStatus {
  RASCUNHO
  GERANDO
  PRONTO
  ERRO
}

// ─── LEADS / KANBAN ────────────────────────────────────────────────────────

model Lead {
  id              String      @id @default(cuid())
  tenantId        String
  imovelId        String?
  nome            String
  whatsapp        String?
  email           String?
  tipoLead        TipoLead    @default(COMPRADOR)
  etapa           EtapaLead   @default(NOVO)
  temperatura     Temperatura @default(MORNO)
  interesse       String?     // tipo de imóvel que busca
  bairroDesejado  String?
  orcamento       Decimal?    @db.Decimal(15, 2)
  resumoConversa  String?
  dataVisita      DateTime?
  followUp1       DateTime?
  followUp2       DateTime?
  followUp3       DateTime?
  // ChatWoot
  chatwootContactId   String?
  chatwootConversaId  String?
  chatwootInboxId     String?
  // n8n
  n8nLeadId       String?
  origem          String?     // site, whatsapp, instagram, etc.
  notas           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel          Imovel?     @relation(fields: [imovelId], references: [id])
  eventos         AgendaEvento[]
  contratos       Contrato[]
  conversas       Conversa[]

  @@index([tenantId, etapa])
  @@index([tenantId, createdAt])
  @@index([tenantId, tipoLead])
  @@map("leads")
}

enum TipoLead {
  COMPRADOR
  LOCATARIO
  VENDEDOR
  LOCADOR
}

model ArtigoBlog {
  id               String    @id @default(cuid())
  tenantId         String
  slug             String
  titulo           String
  resumo           String?
  conteudoMd       String    @default("")
  capaUrl          String?
  tags             String[]  @default([])
  autor            String?
  publicado        Boolean   @default(false)
  publicadoEm      DateTime?
  visualizacoes    Int       @default(0)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, publicado, publicadoEm(sort: Desc)])
  @@map("artigos_blog")
}

model ChaveRetirada {
  id                    String           @id @default(cuid())
  tenantId              String
  imovelId              String
  pessoaNome            String
  pessoaContato         String?
  pessoaTipo            TipoPessoaChave  @default(OUTRO)
  retiradaEm            DateTime         @default(now())
  prazoDevolucao        DateTime?
  devolvidaEm           DateTime?
  status                StatusChave      @default(RETIRADA)
  notas                 String?
  /// Hook n8n: evita disparos duplicados quando cron rodar
  eventoAtrasoEmitido   Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel                Imovel           @relation(fields: [imovelId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, prazoDevolucao])
  @@index([imovelId])
  @@map("chave_retiradas")
}

enum StatusChave {
  RETIRADA
  DEVOLVIDA
}

enum TipoPessoaChave {
  CORRETOR
  VISITA
  MANUTENCAO
  INQUILINO
  PROPRIETARIO
  OUTRO
}

model NewsletterInscricao {
  id                  String   @id @default(cuid())
  tenantId            String
  email               String
  nome                String?
  cidadeInteresse     String?
  tipoInteresse       String?  // CASA / APARTAMENTO / etc.
  operacaoInteresse   String?  // VENDA / ALUGUEL
  precoMax            Decimal? @db.Decimal(15, 2)
  ativo               Boolean  @default(true)
  ultimoEnvio         DateTime?
  tags                String[] @default([])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId, ativo])
  @@map("newsletter_inscricoes")
}

enum EtapaLead {
  NOVO
  CONTATO
  VISITA_AGENDADA
  PROPOSTA
  FECHADO
  PERDIDO
}

enum Temperatura {
  FRIO
  MORNO
  QUENTE
}

// ─── MARCA / WHITE LABEL ───────────────────────────────────────────────────

model ConfigMarca {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  nomeEmpresa     String?
  slogan          String?
  descricao       String?
  logoUrl         String?
  faviconUrl      String?
  corPrimaria     String   @default("#7c3aed")
  corSecundaria   String   @default("#06b6d4")
  // Cor do texto que aparece sobre foto no hero (slogan + descricao).
  // Default branco — user pode trocar pra preto/escuro se foto for clara.
  corTextoHero    String?
  fonteTitulo     String?  @default("cormorant") // cormorant | playfair | lora | inter | montserrat
  fonteCorpo      String?  @default("inter")     // inter | system | montserrat | lora
  email           String?
  whatsapp        String?
  telefone        String?
  endereco        String?
  instagram       String?
  facebook        String?
  youtube         String?
  linkedin        String?
  tiktok          String?
  manualMarcaUrl  String?
  // Paginas legais — textos editaveis pelo tenant. Quando null, o site
  // renderiza o template padrao com nome da empresa interpolado.
  politicaPrivacidade String?
  termosUso           String?
  politicaCookies     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("config_marca")
}

// ─── AGENTE IA ─────────────────────────────────────────────────────────────

model AgenteIA {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  // ─── Persona ───
  nome            String   @default("Sofia")
  personalidade   String   @default("Consultivo e empático")
  apresentacao    String?
  // O que ele deve fazer no atendimento (objetivo)
  objetivo        ObjetivoAgente @default(QUALIFICAR)
  // Mensagens prontas
  mensagemSaudacao    String?
  mensagemForaHorario String?
  // Horário humano (fora disso, IA toma conta sem handoff)
  horarioInicio   String? // ex: "08:00"
  horarioFim      String? // ex: "20:00"
  diasSemana      Json     @default("[1,2,3,4,5]") // 0=dom 6=sab
  ativo           Boolean  @default(false)
  // ─── n8n ───
  usarN8n         Boolean  @default(true)
  webhookUrl      String?
  webhookSecret   String?
  // ─── ChatWoot ───
  usarChatwoot    Boolean  @default(false)
  chatwootUrl     String?
  chatwootToken   String?
  chatwootInboxId String?
  // ─── CRM externo do cliente (callback opcional) ───
  webhookSaidaCrm String?
  // ─── Chaves IA por tenant (NULL = usa master Visualis) ───
  // TODO: cifrar de verdade. Hoje plain text (débito técnico documentado).
  openaiApiKey      String?
  anthropicApiKey   String?
  elevenLabsApiKey  String?
  elevenLabsVoiceId String?
  remotionApiKey    String?
  textoProvider     TextoProvider @default(CLAUDE)
  // ─── Fluxo / etapas configuradas (legado, ainda usado) ───
  etapas          Json     @default("[]")
  // Extensibilidade futura
  metadados       Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("agente_ia")
}

enum ObjetivoAgente {
  QUALIFICAR        // triagem e devolve pro corretor
  AGENDAR_VISITA    // qualifica + agenda direto
  TIRAR_DUVIDAS     // FAQ e info do imóvel
  HANDOFF_DIRETO    // passa pro corretor sem fazer nada
}

enum TextoProvider {
  CLAUDE
  OPENAI
}

// ─── LOGS ESTRUTURADOS ─────────────────────────────────────────────────────

model AiCallLog {
  id              String   @id @default(cuid())
  tenantId        String
  provider        String                          // 'anthropic' | 'openai' | 'elevenlabs' | 'openai-image'
  model           String?
  operation       String                          // 'chat' | 'image-gen' | 'tts' | 'embed' | 'other'
  keySource       String?                         // 'tenant' | 'master'
  promptPreview   String?
  responsePreview String?
  tokensInput     Int?
  tokensOutput    Int?
  costEstimateBrl Decimal? @db.Decimal(10, 4)
  latencyMs       Int?
  status          String   @default("success")    // 'success' | 'error' | 'rate_limited'
  error           String?
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([provider, createdAt(sort: Desc)])
  @@map("ai_call_logs")
}

model ApiRequestLog {
  id            String   @id @default(cuid())
  tenantId      String?
  route         String
  method        String
  status        Int
  latencyMs     Int?
  ip            String?
  userAgent     String?
  userId        String?
  errorMessage  String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([route, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("api_request_logs")
}

// ─── SITE WHITE-LABEL ──────────────────────────────────────────────────────

model Site {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  slug        String   @unique
  dominio     String?  @unique // domínio customizado
  titulo      String?
  publicado   Boolean  @default(false)
  templateId  String?  @default("elegance") // qual template visual está ativo
  config      Json?    // páginas e seções habilitadas (formato em lib/site-config.ts)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("sites")
}

// ─── POSTS / ARTES GERADAS ─────────────────────────────────────────────────

model PostGerado {
  id         String     @id @default(cuid())
  tenantId   String
  imovelId   String?
  tipo       TipoPost
  conteudo   String
  imageUrl   String?
  createdAt  DateTime   @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel     Imovel?    @relation(fields: [imovelId], references: [id])

  @@index([tenantId])
  @@map("posts_gerados")
}

enum TipoPost {
  INSTAGRAM_FEED
  INSTAGRAM_STORIES
  WHATSAPP
  FICHA_PDF
  DESCRICAO_SITE
}

// ─── AGENDA ─────────────────────────────────────────────────────────────────

model AgendaEvento {
  id           String          @id @default(cuid())
  tenantId     String
  // Quem é responsável (corretor) — opcional, default = quem criou
  responsavelId String?
  // Vínculos opcionais
  imovelId     String?
  leadId       String?
  // Dados do evento
  titulo       String
  descricao    String?
  tipo         TipoEvento      @default(VISITA)
  status       StatusEvento    @default(AGENDADO)
  inicio       DateTime
  fim          DateTime
  diaInteiro   Boolean         @default(false)
  local        String?         // texto livre — endereço ou "WhatsApp", etc.
  // Lembretes
  lembrete15Min Boolean        @default(true)
  lembrete1Dia  Boolean        @default(false)
  // Integração futura com Google Calendar
  googleEventId String?
  // Auditoria
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  responsavel  User?           @relation("AgendaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  imovel       Imovel?         @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  lead         Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([tenantId, inicio])
  @@index([tenantId, status])
  @@index([tenantId, responsavelId])
  @@map("agenda_eventos")
}

enum TipoEvento {
  VISITA
  RETORNO
  REUNIAO
  TAREFA
  OUTRO
}

enum StatusEvento {
  AGENDADO
  CONFIRMADO
  REALIZADO
  CANCELADO
  REMARCADO
}

// ─── FINANCEIRO / CONTRATOS ─────────────────────────────────────────────────

model Contrato {
  id              String          @id @default(cuid())
  tenantId        String
  // Vínculos opcionais — o cliente pode existir como Lead OU só como dados livres
  imovelId        String?
  leadId          String?
  // Dados do cliente (cópia direta — não depende do Lead)
  cliente         String          // Nome do cliente
  clienteCpfCnpj  String?
  clienteContato  String?         // WhatsApp ou email
  // Tipo e status
  tipo            TipoContrato    @default(VENDA)
  status          StatusContrato  @default(ATIVO)
  // Valores
  valor           Decimal         @db.Decimal(15, 2)
  comissaoPct     Decimal         @db.Decimal(5, 2) @default(0)  // ex: 5.00 (%)
  // Datas
  dataInicio      DateTime
  dataFim         DateTime?
  // Documento
  pdfUrl          String?         // URL do PDF (Storage no futuro)
  pdfNome         String?
  // Observações
  observacoes     String?
  /// Hook n8n: evita disparos duplicados quando cron varrer "vence em X dias"
  eventoVencimentoEmitido Boolean @default(false)
  /// Tracking de reajuste anual (ALUGUEL/ADMINISTRACAO). Se null, considera dataInicio.
  ultimoReajusteEm        DateTime?
  /// IGPM, IPCA, IPC, livre, ou null
  indexadorReajuste       String?
  /// Hook n8n: evita disparar lembrete duplicado de reajuste anual
  eventoReajusteEmitido   Boolean @default(false)
  // Auditoria
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel          Imovel?         @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  lead            Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  splits          ComissaoSplit[]
  repasses        Repasse[]
  cobrancas       Cobranca[]

  @@index([tenantId, status])
  @@index([tenantId, dataInicio])
  @@index([tenantId, dataFim])
  @@index([tenantId, ultimoReajusteEm])
  @@map("contratos")
}

enum TipoContrato {
  VENDA
  ALUGUEL
  ADMINISTRACAO
  CAPTACAO
}

/// Split de comissao por contrato: corretor que vendeu, captador,
/// imobiliaria, parceiros. Pode ser % ou valor fixo. Mantido como
/// sublinha separada do Contrato pra pipeline financeiro do F7.
model ComissaoSplit {
  id                    String          @id @default(cuid())
  tenantId              String
  contratoId            String
  beneficiario          String          // nome do corretor/captador/empresa
  beneficiarioContato   String?         // wpp/email pra cobranca/aviso
  papel                 PapelComissao   @default(VENDEDOR)
  percentual            Decimal?        @db.Decimal(5, 2)  // % do valor da comissao do contrato
  valorFixo             Decimal?        @db.Decimal(15, 2) // OU valor fixo (mutuamente exclusivo)
  status                StatusComissao  @default(PENDENTE)
  pagoEm                DateTime?
  observacao            String?
  /// Hook n8n: evita disparar lembrete de pagamento duplicado
  eventoCobrancaEmitido Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato              Contrato        @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([contratoId])
  @@index([tenantId, pagoEm])
  @@map("comissao_splits")
}

enum PapelComissao {
  VENDEDOR
  CAPTADOR
  IMOBILIARIA
  PARCEIRO
  OUTRO
}

enum StatusComissao {
  PENDENTE
  PAGO
  CANCELADO
}

/// Repasse mensal pro proprietario na locacao administrada.
/// 1 linha = 1 mes/contrato (unique constraint contratoId+mesReferencia).
model Repasse {
  id                    String          @id @default(cuid())
  tenantId              String
  contratoId            String
  proprietarioNome      String
  proprietarioContato   String?
  proprietarioConta     String?         // chave PIX, banco/agencia/conta livre
  mesReferencia         String          // YYYY-MM (ex: "2026-05")
  valorBruto            Decimal         @db.Decimal(15, 2)  // recebido do inquilino
  taxaAdmPct            Decimal?        @db.Decimal(5, 2)
  taxaAdmFixa           Decimal?        @db.Decimal(15, 2)
  outrosDescontos       Decimal         @default(0) @db.Decimal(15, 2)
  descontosNotas        String?
  valorLiquido          Decimal         @db.Decimal(15, 2)  // a repassar
  status                StatusRepasse   @default(PENDENTE)
  pagoEm                DateTime?
  comprovanteUrl        String?
  observacao            String?
  /// Hook n8n: evita duplicar lembrete
  eventoCobrancaEmitido Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato              Contrato        @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  cobrancas             Cobranca[]

  @@unique([contratoId, mesReferencia])
  @@index([tenantId, status])
  @@index([tenantId, mesReferencia])
  @@map("repasses")
}

enum StatusRepasse {
  PENDENTE      // aluguel ainda nao pago pelo inquilino
  A_REPASSAR    // inquilino pagou, falta repassar
  PAGO          // repasse concluido
  CANCELADO
}

/// Cobranca em aberto — aluguel atrasado, multa, IPTU rateado,
/// taxa avulsa. Pode estar ligada a um contrato e/ou repasse
/// (origem) ou ser totalmente avulsa.
model Cobranca {
  id                    String          @id @default(cuid())
  tenantId              String
  contratoId            String?
  repasseId             String?
  devedorNome           String
  devedorContato        String?
  devedorCpfCnpj        String?
  descricao             String          // ex: "Aluguel mai/26", "Multa atraso"
  valorOriginal         Decimal         @db.Decimal(15, 2)
  multaPct              Decimal?        @db.Decimal(5, 2)  // ex 2%
  jurosDiariosPct       Decimal?        @db.Decimal(5, 2)  // ex 0.033%/dia
  vencimento            DateTime
  status                StatusCobranca  @default(ABERTO)
  pagoEm                DateTime?
  valorPago             Decimal?        @db.Decimal(15, 2)
  formaPagamento        String?
  /// Historico JSON de tentativas: [{data, canal, status, conteudo}]
  historicoCobranca     Json            @default("[]")
  observacao            String?
  /// Hook n8n: evita disparo duplicado no mesmo dia
  eventoCobrancaEmitido Boolean         @default(false)
  ultimaCobrancaEm      DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contrato              Contrato?       @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  repasse               Repasse?        @relation(fields: [repasseId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, vencimento])
  @@map("cobrancas")
}

enum StatusCobranca {
  ABERTO       // pode estar no prazo ou atrasada — UI decide visual
  PAGO
  NEGOCIADO    // parcelado/acordo
  CANCELADO
}

enum StatusContrato {
  ATIVO
  PENDENTE
  ENCERRADO
  CANCELADO
}

// ─── ATENDIMENTO IA (WhatsApp + RAG) ───────────────────────────────────────

/// Conexão do tenant ao provider WhatsApp (WAHA, Evolution ou Cloud API).
/// Ver docs em 09_Squads/.../06_Arquitetura_IA/02_WhatsApp_Provider.md
model ConfigWhatsApp {
  id              String       @id @default(cuid())
  tenantId        String       @unique
  providerType    WppProvider
  instanceName    String       // identifier no provider (ex: tenant slug)
  baseUrl         String?      // URL do servidor (self-hosted WAHA/Evolution)
  apiKeyEncrypted String?      // criptografado em rest
  webhookSecret   String?      // valida origem do webhook
  numeroConectado String?      // ex: 5511999998888
  status          WppStatus    @default(DISCONNECTED)
  conectadoEm     DateTime?
  desconectadoEm  DateTime?
  ultimoErro      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("config_whatsapp")
}

enum WppProvider {
  WAHA
  EVOLUTION
  CLOUD_API
}

enum WppStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  BANNED
  ERROR
}

/// Conversa WhatsApp entre lead e tenant. Pode ter N mensagens.
model Conversa {
  id               String     @id @default(cuid())
  tenantId         String
  clienteWa        String     // numero WhatsApp normalizado: 5511999998888
  clienteNome      String?
  status           ConvStatus @default(IA)        // IA atendendo OU corretor assumiu OU encerrada
  imovelId         String?    // se conversa eh sobre imovel especifico
  leadId           String?    // vinculado ao Lead apos qualificacao
  providerType    WppProvider
  providerInstance String                          // identifier no provider
  iniciadaEm       DateTime   @default(now())
  ultimaMsgEm      DateTime   @default(now())
  fechadaEm        DateTime?
  fechadaPor       String?                         // userId que fechou
  resumoLLM        String?    @db.Text             // resumo gerado pela IA pro CRM

  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  imovel           Imovel?    @relation(fields: [imovelId], references: [id], onDelete: SetNull)
  lead             Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  mensagens        Mensagem[]

  @@index([tenantId, status])
  @@index([tenantId, clienteWa])
  @@index([tenantId, ultimaMsgEm])
  @@map("conversas")
}

enum ConvStatus {
  IA
  HUMANO
  FECHADA
}

/// Mensagem individual dentro de uma Conversa.
model Mensagem {
  id          String     @id @default(cuid())
  conversaId  String
  tenantId    String                                 // denormalizado pra queries rapidas
  direcao     MsgDirecao                             // IN (cliente) | OUT (sistema)
  autorTipo   MsgAutor                               // IA | HUMANO | CLIENTE | SISTEMA
  autorId     String?                                // userId se HUMANO; null se IA/CLIENTE
  tipo        MsgTipo                                // TEXTO | AUDIO | IMAGEM | VIDEO | DOC | LOCALIZACAO
  conteudo    String     @db.Text                    // texto OU transcricao OU caption
  anexoUrl    String?                                // url no Supabase Storage
  anexoMime   String?
  providerMsgId String?                              // ID original no WAHA/Evolution/Meta
  metadata    Json?                                  // { replyTo, reactions, ... }
  createdAt   DateTime   @default(now())

  conversa    Conversa   @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversaId, createdAt])
  @@index([tenantId, createdAt])
  @@map("mensagens")
}

enum MsgDirecao {
  IN
  OUT
}

enum MsgAutor {
  IA
  HUMANO
  CLIENTE
  SISTEMA
}

enum MsgTipo {
  TEXTO
  AUDIO
  IMAGEM
  VIDEO
  DOC
  LOCALIZACAO
}

/// Convite de membro pra equipe (tenant). Admin gera o token, mandando
/// o link pelo canal que preferir (WhatsApp, email, etc). O convidado
/// abre /convite/[token], define senha e vira User do tenant.
model EquipeConvite {
  id               String    @id @default(cuid())
  tenantId         String
  email            String
  role             Role      @default(CORRETOR)
  token            String    @unique
  invitedBy        String    // userId do admin que convidou
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  createdAt        DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@map("equipe_convites")
}
